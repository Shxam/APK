# IPL Dhaba Backend — Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit .env to git

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ─── RESEND (Email) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
# Leave blank to disable email notifications
RESEND_API_KEY=

# ─── RESTAURANT EMAIL ─────────────────────────────────────────────────────────
# The restaurant owner's email for new order notifications
RESTAURANT_EMAIL=owner@ipldhaba.com

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Frontend URL. For local dev: http://localhost:8080
# For production: https://yourapp.vercel.app
ALLOWED_ORIGIN=http://localhost:8080

# ─── JWT SECRET ───────────────────────────────────────────────────────────────
# Only used for signing internal tokens if needed; Supabase JWT is primary auth
JWT_SECRET=change-me-to-a-random-64-char-string
